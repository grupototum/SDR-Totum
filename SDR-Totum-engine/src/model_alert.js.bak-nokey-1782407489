/* model_alert.js — classificador de saúde da cadeia LLM a partir dos logs do generate() (llm_provider.js).
 * ADITIVO: função pura, sem deps, sem efeito colateral. NÃO importado pelo server.js ainda.
 * Objetivo (hardening Fase 2, condição do teste Dev da Fase 1):
 *   separar FAILOVER transitório (a cadeia se recuperou) de FALHA REAL (cadeia esgotada),
 *   SEM esconder erro persistente de config (401/413/sem-chave) que vai recorrer.
 *
 * Entrada: linhas de log de UMA chamada generate() (prod), na ordem emitida.
 *   sucesso:  "[llm] prod nvidia/meta/llama-4-... 850ms"
 *   falha:    "[llm] groq falhou (groq 429 ...) 120ms; tentando próximo"
 *   vazia:    "[llm] groq resposta vazia 80ms; tentando próximo"
 * Saída: { level: 'OK'|'WARN'|'ALERT', reason, recovered, exhausted, attempts:[{provider,kind,persistent}] }
 *
 * Regra:
 *   ALERT  = cadeia esgotada (nenhum sucesso) → falha real, paginar.
 *   WARN   = recuperou, MAS apareceu erro PERSISTENTE (auth/payload/sem-chave) → não esconder (chave/config quebrada).
 *   OK     = recuperou só com erro TRANSITÓRIO (429/timeout/5xx/vazia) OU sucesso direto.
 */
'use strict';

// classifica a mensagem de erro de um provider em um "kind" e se é persistente (vai recorrer)
function classifyError(msg) {
  const m = String(msg || '');
  if (/\bsem chave\b/i.test(m))                 return { kind: 'no_key',    persistent: true };
  if (/\b401\b|\b403\b|unauthor/i.test(m))      return { kind: 'auth',      persistent: true };
  if (/\b413\b|too large|payload/i.test(m))     return { kind: 'payload',   persistent: true };
  if (/\b429\b|rate.?limit/i.test(m))           return { kind: 'ratelimit', persistent: false };
  if (/abort|timed?\s?out|timeout|stall/i.test(m)) return { kind: 'timeout', persistent: false };
  if (/\b5\d\d\b/.test(m))                       return { kind: 'server',    persistent: false };
  if (/resposta vazia|empty/i.test(m))          return { kind: 'empty',     persistent: false };
  return { kind: 'unknown', persistent: false };
}

const RE_SUCCESS = /\[llm\]\s+\w+\s+[\w.-]+\/\S+\s+\d+ms/;          // "[llm] prod nvidia/model 850ms"
const RE_FAIL    = /\[llm\]\s+([\w.-]+)\s+falhou\s+\(([^)]*)\)/;     // "[llm] groq falhou (groq 429 ...)"
const RE_EMPTY   = /\[llm\]\s+([\w.-]+)\s+resposta vazia/;          // "[llm] groq resposta vazia ..."

function classifyLlmLogs(input) {
  const lines = Array.isArray(input) ? input : String(input || '').split(/\r?\n/);
  const attempts = [];
  let recovered = false;

  for (const line of lines) {
    if (!line || !line.includes('[llm]')) continue;
    if (RE_FAIL.test(line) || RE_EMPTY.test(line)) {
      const mf = line.match(RE_FAIL);
      if (mf) { const c = classifyError(mf[2]); attempts.push({ provider: mf[1], ...c }); continue; }
      const me = line.match(RE_EMPTY);
      if (me) { attempts.push({ provider: me[1], kind: 'empty', persistent: false }); continue; }
    } else if (RE_SUCCESS.test(line)) {
      recovered = true; // sucesso de algum provider na cadeia
    }
  }

  const exhausted = !recovered && attempts.length > 0;
  const persistent = attempts.filter((a) => a.persistent);

  if (exhausted) {
    const kinds = [...new Set(attempts.map((a) => a.kind))].join(',');
    return { level: 'ALERT', reason: `cadeia LLM esgotada sem resposta (${attempts.length} tentativas: ${kinds})`, recovered, exhausted, attempts };
  }
  if (recovered && persistent.length) {
    const who = persistent.map((a) => `${a.provider}:${a.kind}`).join(', ');
    return { level: 'WARN', reason: `recuperou via failover, mas erro persistente que vai recorrer: ${who}`, recovered, exhausted, attempts };
  }
  if (recovered && attempts.length) {
    const who = attempts.map((a) => `${a.provider}:${a.kind}`).join(', ');
    return { level: 'OK', reason: `failover transitório absorvido (${who})`, recovered, exhausted, attempts };
  }
  return { level: 'OK', reason: 'sucesso direto', recovered: true, exhausted: false, attempts };
}

module.exports = { classifyLlmLogs, classifyError };
