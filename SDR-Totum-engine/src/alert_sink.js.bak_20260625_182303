/* alert_sink.js — sink de alerta de saúde do modelo LLM.
 * Escreve sinal em arquivo para o monitor totum-ops ler.
 * ALERT  = sobrescreve SDR_ALERT_FILE (paginável); log console.error.
 * WARN   = append em SDR_DIGEST_FILE; log console.warn.
 * Throttle por nível: não pagina mais de 1x por SDR_ALERT_THROTTLE_MS (default 10min).
 */
"use strict";
const fs = require("node:fs");

const ALERT_FILE    = process.env.SDR_ALERT_FILE    || "/tmp/sdr-llm-alert.json";
const DIGEST_FILE   = process.env.SDR_DIGEST_FILE   || "/tmp/sdr-llm-digest.jsonl";
const THROTTLE_MS   = Number(process.env.SDR_ALERT_THROTTLE_MS || 10 * 60 * 1000); // 10 min

let _lastAlertAt = 0;
let _lastWarnAt  = 0;

function emit({ level, reason, recovered = false, exhausted = false, attempts = [] }) {
  const now = Date.now();
  const ts  = new Date().toISOString();

  if (level === "ALERT") {
    if (now - _lastAlertAt < THROTTLE_MS) return; // throttle
    _lastAlertAt = now;
    const payload = JSON.stringify({ level, reason, exhausted, attempts, ts }, null, 2);
    try { fs.writeFileSync(ALERT_FILE, payload, "utf8"); } catch (e) { console.error("[alert_sink] write ALERT falhou:", e.message); }
    console.error(`[SDR→OPS] ⚠️  ALERT LLM: ${reason}`);

  } else if (level === "WARN") {
    if (now - _lastWarnAt < THROTTLE_MS) return; // throttle
    _lastWarnAt = now;
    const line = JSON.stringify({ level, reason, recovered, attempts, ts }) + "\n";
    try { fs.appendFileSync(DIGEST_FILE, line, "utf8"); } catch (e) { console.error("[alert_sink] append WARN falhou:", e.message); }
    console.warn(`[SDR→OPS] ⚠️  WARN LLM: ${reason}`);
  }
  // OK: não logar nada extra
}

// Reset de throttle (útil p/ testes)
function _resetThrottle() { _lastAlertAt = 0; _lastWarnAt = 0; }

module.exports = { emit, _resetThrottle };
