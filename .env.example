# ─── Server-only (NÃO usar prefixo VITE_ — VITE_* compila no bundle do browser) ───
# URL do motor SDR (interno na VPS ou domínio que faça proxy).
ENGINE_URL=https://engine.grupototum.com
# Chave do motor. Server-side only. NUNCA commitar o valor real.
SDR_API_KEY=

# URL da API do n8n. Cliente fala só same-origin (/api/n8n); o servidor injeta a key.
N8N_API_URL=https://seu-n8n.example.com/api/v1
# Chave do n8n (header X-N8N-API-KEY). Server-side only. NUNCA commitar o valor real.
N8N_API_KEY=

# ─── Client ───
# Vazio = mock local (sem rede). Preenchido = usa o proxy same-origin.
# Use o proxy same-origin (a chave é injetada no servidor, nunca no browser):
VITE_API_BASE_URL=/api/engine
