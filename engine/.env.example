# === LLM (obrigatório em produção) ===
# SDR_LLM=nvidia | groq | mock (teste de plumbing sem chave)
SDR_LLM=nvidia
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === Evolution API (WhatsApp) ===
EVOLUTION_URL=
EVOLUTION_KEY=
EVOLUTION_INSTANCE=

# === Serviço ===
PORT=3010
DB_PATH=./data/sdr.db
DEBOUNCE_MS=4000

# Link de agenda (opcional; sem ele o bot propõe horários manualmente)
LINK_AGENDA=

# Nome do SDR humano que assina a conversa
NOME_SDR=Rael

# LP de amostra enviada nos encerramentos
LINK_LP=https://lp.grupototum.com/
