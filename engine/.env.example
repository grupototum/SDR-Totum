# === LLM (obrigatório em produção) ===
# SDR_LLM=nvidia | groq | mock (teste de plumbing sem chave)
SDR_LLM=nvidia
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === Evolution API (WhatsApp) ===
EVOLUTION_URL=
EVOLUTION_KEY=
EVOLUTION_INSTANCE=

# === Serviço ===
PORT=3010
DB_PATH=./data/sdr.db
DEBOUNCE_MS=4000

# === Humanização de tráfego (engine/src/dispatch.js) ===
# Identifica a instância p/ ramp-up e teto diário (uma por número de WhatsApp).
INSTANCE_ID=default
# Ramp-up diário por dia de vida do número (dia1,dia2,...,dia7+). Satura no último valor.
DISPATCH_RAMP=5,8,12,18,25,35,50
# Intervalo aleatório (ms) entre aberturas — nunca fixo.
JITTER_MIN=300000
JITTER_MAX=900000
# Janela comercial (horário local); fora dela, disparo é adiado pro próximo dia útil.
WINDOW_START=09:00
WINDOW_END=19:00
# Anti-template: compara a abertura gerada com as últimas N enviadas (Jaccard >= threshold pede reformulação).
ANTI_TEMPLATE_N=5
ANTI_TEMPLATE_THRESHOLD=0.6

# Link de agenda (opcional; sem ele o bot propõe horários manualmente)
LINK_AGENDA=

# Nome do SDR humano que assina a conversa
NOME_SDR=Rael

# LP de amostra enviada nos encerramentos
LINK_LP=https://lp.grupototum.com/
